{
    "name": "@geti-ui/mcp",
    "version": "1.0.3",
    "description": "MCP server for Geti UI documentation: exposes component, chart, and smart-tools docs to AI coding agents",
    "type": "module",
    "bin": {
        "geti-ui-mcp": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "rslib build && node scripts/bundle-docs.mjs",
        "start": "node dist/index.js",
        "dev": "node --enable-source-maps dist/index.js",
        "type-check": "tsc --noEmit",
        "test": "rstest run",
        "test:watch": "rstest",
        "lint": "rslint",
        "lint:fix": "rslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.17.3",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@rslib/core": "^0.10.5",
        "@rslint/core": "^0.2.1",
        "@rstest/core": "^0.2.2",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/MarkRedeman/geti-ui",
        "directory": "packages/mcp"
    },
    "homepage": "https://docs.geti-ui.markredeman.nl"
}
