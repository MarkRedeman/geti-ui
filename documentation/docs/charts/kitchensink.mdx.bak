---
title: Kitchensink
---

# Charts kitchensink

Single page showing all currently available `@geti-ai/charts` primitives and chart components.

## LineChart

```tsx preview
import { LineChart } from '@geti-ai/charts';

const data = [
  { epoch: 1, train: 1.42, val: 1.50 },
  { epoch: 2, train: 1.10, val: 1.20 },
  { epoch: 3, train: 0.87, val: 0.98 },
  { epoch: 4, train: 0.71, val: 0.82 },
  { epoch: 5, train: 0.60, val: 0.69 },
  { epoch: 6, train: 0.52, val: 0.61 },
];

export default function App() {
  return (
    <LineChart
      data={data}
      xAxisKey="epoch"
      series={[
        { dataKey: 'train', name: 'Train loss' },
        { dataKey: 'val', name: 'Val loss' },
      ]}
      aria-label="Training and validation loss"
      height={260}
    />
  );
}
```

## BarChart

```tsx preview
import { BarChart } from '@geti-ai/charts';

const data = [
  { model: 'MobileNet', precision: 84, recall: 80 },
  { model: 'ResNet-50', precision: 89, recall: 87 },
  { model: 'EfficientDet', precision: 91, recall: 90 },
];

export default function App() {
  return (
    <BarChart
      data={data}
      xAxisKey="model"
      series={[
        { dataKey: 'precision', name: 'Precision (%)' },
        { dataKey: 'recall', name: 'Recall (%)' },
      ]}
      aria-label="Precision and recall per model"
      height={260}
    />
  );
}
```

## AreaChart

```tsx preview
import { AreaChart } from '@geti-ai/charts';

const data = [
  { step: 1, train: 0.45, val: 0.41 },
  { step: 2, train: 0.51, val: 0.46 },
  { step: 3, train: 0.62, val: 0.57 },
  { step: 4, train: 0.71, val: 0.65 },
  { step: 5, train: 0.77, val: 0.72 },
  { step: 6, train: 0.82, val: 0.76 },
];

export default function App() {
  return (
    <AreaChart
      data={data}
      xAxisKey="step"
      series={[
        { dataKey: 'train', name: 'Train IoU' },
        { dataKey: 'val', name: 'Val IoU' },
      ]}
      aria-label="IoU over training steps"
      height={260}
    />
  );
}
```

## ScatterChart

```tsx preview
import { ScatterChart } from '@geti-ai/charts';

const points = [
  { x: 0.1, y: 0.85, name: 'cat' },
  { x: 0.3, y: 0.72, name: 'dog' },
  { x: 0.5, y: 0.91, name: 'car' },
  { x: 0.2, y: 0.68, name: 'person' },
  { x: 0.7, y: 0.77, name: 'bicycle' },
  { x: 0.4, y: 0.83, name: 'truck' },
  { x: 0.6, y: 0.95, name: 'bus' },
];

export default function App() {
  return (
    <ScatterChart
      series={[{ name: 'Per class', data: points }]}
      xAxisLabel="False positive rate"
      yAxisLabel="True positive rate"
      aria-label="ROC-style class scatter"
      height={280}
    />
  );
}
```

## Sparkline

```tsx preview
import { Sparkline } from '@geti-ai/charts';

export default function App() {
  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
      <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
        <span style={{ color: 'var(--spectrum-global-color-gray-300)', fontSize: 13, width: 120 }}>
          MobileNet v3
        </span>
        <Sparkline data={[72, 75, 79, 81, 83, 85, 88].map((value) => ({ value }))} />
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
        <span style={{ color: 'var(--spectrum-global-color-gray-300)', fontSize: 13, width: 120 }}>
          ResNet-50
        </span>
        <Sparkline data={[80, 82, 84, 86, 87, 89, 91].map((value) => ({ value }))} />
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
        <span style={{ color: 'var(--spectrum-global-color-gray-300)', fontSize: 13, width: 120 }}>
          EfficientDet
        </span>
        <Sparkline data={[60, 65, 70, 74, 80, 84, 90].map((value) => ({ value }))} />
      </div>
    </div>
  );
}
```

## Primitives quick example

```tsx preview
import { ComposedChart, Line } from 'recharts';
import {
  GetiCartesianGrid,
  GetiXAxis,
  GetiYAxis,
  GetiTooltip,
  GetiLegend,
  GetiResponsiveContainer,
} from '@geti-ai/charts/primitives';

const data = [
  { t: '09:00', valA: 42, valB: 55 },
  { t: '10:00', valA: 58, valB: 63 },
  { t: '11:00', valA: 53, valB: 60 },
  { t: '12:00', valA: 67, valB: 72 },
  { t: '13:00', valA: 71, valB: 77 },
];

export default function App() {
  return (
    <GetiResponsiveContainer height={260}>
      <ComposedChart data={data}>
        <GetiCartesianGrid />
        <GetiXAxis dataKey="t" />
        <GetiYAxis />
        <GetiTooltip />
        <GetiLegend />
        <Line type="monotone" dataKey="valA" stroke="#4C9BE8" dot={false} isAnimationActive={false} />
        <Line type="monotone" dataKey="valB" stroke="#5CE6A2" dot={false} isAnimationActive={false} />
      </ComposedChart>
    </GetiResponsiveContainer>
  );
}
```
