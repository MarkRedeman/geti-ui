{
    "name": "@geti-ui/charts",
    "version": "1.2.0",
    "description": "Geti UI charts component library built on Recharts",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        },
        "./primitives": {
            "import": "./dist/esm/primitives.js",
            "require": "./dist/cjs/primitives.cjs",
            "types": "./dist/types/primitives.d.ts"
        }
    },
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "rslib build --watch",
        "build": "rslib build",
        "build:watch": "rslib build --watch",
        "test": "rstest run",
        "test:watch": "rstest",
        "type-check": "tsc --noEmit -p tsconfig.json",
        "lint": "rslint",
        "lint:fix": "rslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "peerDependencies": {
        "recharts": "^3.8.0",
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    },
    "dependencies": {
        "d3-delaunay": "^6.0.4"
    },
    "devDependencies": {
        "@rsbuild/core": "^1.7.3",
        "@rsbuild/plugin-react": "^1.4.5",
        "@rslib/core": "^0.12.2",
        "@rslint/core": "^0.2.1",
        "@rstest/core": "^0.2.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "jsdom": "^28.1.0",
        "null-loader": "^4.0.1",
        "prettier": "^3.8.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "recharts": "^3.8.0",
        "typescript": "^5.9.3"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MarkRedeman/geti-ui.git",
        "directory": "packages/charts"
    },
    "license": "Apache-2.0",
    "homepage": "https://docs.geti-ui.markredeman.nl"
}
