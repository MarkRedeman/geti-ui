{
    "name": "@geti-ui/ui",
    "version": "1.3.0",
    "description": "Geti UI component design system",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        },
        "./styles.css": {
            "default": "./dist/esm/index.css"
        },
        "./icons": {
            "import": "./dist/esm/icons.js",
            "require": "./dist/cjs/icons.cjs",
            "types": "./dist/types/assets/icons/index.d.ts"
        },
        "./assets": {
            "import": "./dist/esm/assets.js",
            "require": "./dist/cjs/assets.cjs",
            "types": "./dist/types/assets/index.d.ts"
        },
        "./assets/images": {
            "import": "./dist/esm/assets/images.js",
            "require": "./dist/cjs/assets/images.cjs",
            "types": "./dist/types/assets/images/index.d.ts"
        },
        "./assets/domains": {
            "import": "./dist/esm/assets/domains.js",
            "require": "./dist/cjs/assets/domains.cjs",
            "types": "./dist/types/assets/domains/index.d.ts"
        },
        "./assets/primary-tools": {
            "import": "./dist/esm/assets/primary-tools.js",
            "require": "./dist/cjs/assets/primary-tools.cjs",
            "types": "./dist/types/assets/primary-tools/index.d.ts"
        }
    },
    "sideEffects": [
        "*.css"
    ],
    "style": "./dist/esm/index.css",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "rslib build --watch",
        "build": "rslib build",
        "build:watch": "rslib build --watch",
        "test": "rstest run",
        "test:watch": "rstest",
        "test:e2e": "playwright test",
        "type-check": "tsc --noEmit -p tsconfig.json",
        "lint": "rslint",
        "lint:fix": "rslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    },
    "dependencies": {
        "@adobe/react-spectrum": "^3.46.2",
        "@react-aria/color": "3.2.0",
        "@react-aria/utils": "^3.33.1",
        "@react-spectrum/utils": "^3.12.12",
        "@react-stately/color": "3.10.0",
        "@react-stately/virtualizer": "^4.4.6",
        "@react-types/shared": "^3.33.1",
        "@spectrum-icons/workflow": "^4.2.28",
        "clsx": "^2.1.1",
        "react-aria-components": "^1.16.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@react-types/datepicker": "^3.13.5",
        "@react-types/provider": "^3.8.15",
        "@react-types/textfield": "^3.12.8",
        "@rsbuild/core": "^2.0.0",
        "@rsbuild/plugin-react": "^2.0.0",
        "@rsbuild/plugin-svgr": "^2.0.0",
        "@rslint/core": "^0.5.0",
        "@rslib/core": "^0.21.0",
        "@rstest/core": "^0.9.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/jsdom": "^28.0.0",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "jsdom": "^29.0.0",
        "null-loader": "^4.0.1",
        "prettier": "^3.8.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "remark-gfm": "^4.0.1",
        "typescript": "^6.0.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MarkRedeman/geti-ui.git",
        "directory": "packages/ui"
    },
    "license": "Apache-2.0",
    "homepage": "https://docs.geti-ui.markredeman.nl"
}
