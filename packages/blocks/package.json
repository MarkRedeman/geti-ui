{
    "name": "@geti-ui/blocks",
    "version": "1.3.0",
    "description": "Geti UI reusable application blocks",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        },
        "./styles.css": {
            "default": "./dist/esm/index.css"
        }
    },
    "style": "./dist/esm/index.css",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "sideEffects": [
        "*.css"
    ],
    "scripts": {
        "dev": "rslib build --watch",
        "build": "rslib build",
        "build:watch": "rslib build --watch",
        "test": "rstest run",
        "test:watch": "rstest",
        "type-check": "tsc --noEmit -p tsconfig.json",
        "lint": "rslint",
        "lint:fix": "rslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "peerDependencies": {
        "@react-aria/utils": "^3.33.1",
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    },
    "dependencies": {
        "@geti-ui/ui": "*",
        "@use-gesture/react": "^10.3.1"
    },
    "devDependencies": {
        "@rsbuild/core": "^2.0.0",
        "@rsbuild/plugin-react": "^2.0.0",
        "@rslib/core": "^0.21.0",
        "@rslint/core": "^0.5.0",
        "@rstest/core": "^0.9.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@react-aria/utils": "^3.33.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "jsdom": "^29.0.0",
        "null-loader": "^4.0.1",
        "prettier": "^3.8.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "typescript": "^6.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MarkRedeman/geti-ui.git",
        "directory": "packages/blocks"
    },
    "license": "Apache-2.0",
    "homepage": "https://docs.geti-ui.markredeman.nl"
}
