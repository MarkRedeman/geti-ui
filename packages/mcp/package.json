{
  "name": "@geti-ai/mcp",
  "version": "0.0.1",
  "description": "MCP server for Geti UI documentation — exposes component, chart, and smart-tools docs to AI coding agents",
  "type": "module",
  "bin": {
    "geti-ui-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rslib build && node scripts/bundle-docs.mjs",
    "start": "node dist/index.js",
    "dev": "node --enable-source-maps dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@rslib/core": "^0.10.5",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-edge-platform/geti-ui",
    "directory": "packages/mcp"
  }
}
