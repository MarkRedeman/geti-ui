{
    "name": "@geti/ui",
    "version": "0.0.1",
    "description": "Geti UI component design system",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rslib build",
        "build:watch": "rslib build --watch",
        "storybook": "storybook dev -p 6006",
        "storybook:build": "storybook build -o storybook-static",
        "test": "rstest run",
        "test:watch": "rstest",
        "test:e2e": "playwright test",
        "type-check": "tsc --noEmit -p tsconfig.json",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "dependencies": {
        "@adobe/react-spectrum": "^3.46.2",
        "@react-aria/color": "3.1.5",
        "@react-aria/utils": "^3.33.1",
        "@react-spectrum/utils": "^3.12.12",
        "@react-stately/color": "3.9.5",
        "@react-stately/virtualizer": "^4.4.6",
        "@react-types/shared": "^3.33.1",
        "@spectrum-icons/workflow": "^4.2.28",
        "clsx": "^2.1.1",
        "react-aria-components": "^1.16.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@react-types/datepicker": "^3.13.5",
        "@react-types/provider": "^3.8.15",
        "@react-types/textfield": "^3.12.8",
        "@rsbuild/core": "^1.7.3",
        "@rsbuild/plugin-react": "^1.4.5",
        "@rslib/core": "^0.12.2",
        "@rstest/core": "^0.2.2",
        "@storybook/addon-a11y": "10.2.16",
        "@storybook/addon-docs": "10.2.16",
        "@storybook/react": "10.2.16",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/jsdom": "^28.0.0",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "jsdom": "^28.1.0",
        "null-loader": "^4.0.1",
        "prettier": "^3.8.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "remark-gfm": "^4.0.1",
        "storybook": "10.2.16",
        "storybook-addon-rslib": "latest",
        "storybook-builder-rsbuild": "3.3.0",
        "storybook-react-rsbuild": "^3.3.0",
        "typescript": "^5.9.3"
    }
}
