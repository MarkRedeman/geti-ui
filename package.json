{
  "name": "geti-ui-workspace",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @geti/ui build",
    "storybook": "pnpm --filter @geti/ui storybook",
    "storybook:build": "pnpm --filter @geti/ui storybook:build",
    "test": "pnpm --filter @geti/ui test",
    "test:watch": "pnpm --filter @geti/ui test:watch",
    "test:e2e": "pnpm --filter @geti/ui test:e2e",
    "type-check": "pnpm --filter @geti/ui type-check",
    "lint": "pnpm --filter @geti/ui lint",
    "format": "pnpm --filter @geti/ui format",
    "format:check": "pnpm --filter @geti/ui format:check",
    "prepare": "husky",
    "docs:dev": "pnpm --filter @geti/documentation dev",
    "docs:dev:with-ui": "pnpm --parallel --stream --filter @geti/ui --filter @geti/documentation run dev",
    "docs:build": "pnpm --filter @geti/documentation build",
    "docs:preview": "pnpm --filter @geti/documentation preview",
    "docs:check:coverage": "pnpm --filter @geti/documentation check:coverage",
    "docs:check:no-stories-imports": "pnpm --filter @geti/documentation check:no-stories-imports",
    "docs:test:e2e": "pnpm --filter @geti/documentation test:e2e"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.8.0+sha512.8e4c3550fb500e808dbc30bb0ce4dd1eb614e30b1c55245f211591ec2cdf9c611cabd34e1364b42f564bd54b3945ed0f49d61d1bbf2ec9bd74b866fcdc723276",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.56.1"
  }
}
