{
    "name": "@geti/ui",
    "version": "0.0.1",
    "description": "Geti UI component design system",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rslib build",
        "build:watch": "rslib build --watch",
        "storybook": "storybook dev -p 6006",
        "storybook:build": "storybook build -o storybook-static",
        "test": "rstest run",
        "test:watch": "rstest",
        "test:e2e": "playwright test",
        "type-check": "tsc --noEmit -p tsconfig.json",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "dependencies": {
        "@adobe/react-spectrum": "^3.43.0",
        "@react-aria/utils": "^3.33.1",
        "@react-spectrum/utils": "^3.12.12",
        "@react-stately/virtualizer": "^4.4.6",
        "@react-types/shared": "^3.33.1",
        "@spectrum-icons/workflow": "^4.2.28",
        "clsx": "^2.1.1",
        "react-aria-components": "^1.11.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.50.0",
        "@react-types/datepicker": "^3.13.5",
        "@react-types/provider": "*",
        "@react-types/textfield": "*",
        "@rsbuild/core": "^1.5.0",
        "@rsbuild/plugin-react": "^1.0.0",
        "@rslib/core": "^0.12.0",
        "@rstest/core": "^0.2.0",
        "@storybook/addon-a11y": "^10.0.0",
        "@storybook/addon-docs": "^10.2.16",
        "@storybook/react": "^10.2.16",
        "@testing-library/jest-dom": "^6.6.4",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/jsdom": "^28.0.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "jsdom": "^28.1.0",
        "null-loader": "^4.0.1",
        "prettier": "^3.5.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "storybook": "latest",
        "storybook-addon-rslib": "latest",
        "storybook-react-rsbuild": "latest",
        "typescript": "^5.8.0"
    }
}
