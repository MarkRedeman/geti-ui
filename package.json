{
  "name": "geti-ui-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "documentation"
  ],
  "scripts": {
    "build": "npm run build --workspace=@geti/ui",
    "storybook": "npm run storybook --workspace=@geti/ui",
    "storybook:build": "npm run storybook:build --workspace=@geti/ui",
    "test": "npm run test --workspace=@geti/ui",
    "test:watch": "npm run test:watch --workspace=@geti/ui",
    "test:e2e": "npm run test:e2e --workspace=@geti/ui",
    "type-check": "npm run type-check --workspace=@geti/ui",
    "lint": "npm run lint --workspace=@geti/ui",
    "format": "npm run format --workspace=@geti/ui",
    "format:check": "npm run format:check --workspace=@geti/ui",
    "prepare": "husky",
    "docs:dev": "npm run dev --workspace=@geti/documentation",
    "docs:dev:with-ui": "concurrently -n ui,docs -c auto \"npm run dev --workspace=@geti/ui\" \"npm run dev --workspace=@geti/documentation\"",
    "docs:build": "npm run build --workspace=@geti/documentation",
    "docs:preview": "npm run preview --workspace=@geti/documentation",
    "docs:check:coverage": "npm run check:coverage --workspace=@geti/documentation",
    "docs:check:no-stories-imports": "npm run check:no-stories-imports --workspace=@geti/documentation",
    "docs:test:e2e": "npm run test:e2e --workspace=@geti/documentation"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.0.0",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "concurrently": "^9.2.1",
    "typescript-eslint": "^8.56.1"
  }
}
